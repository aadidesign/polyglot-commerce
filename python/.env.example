# Copy to .env for running outside Docker (uvicorn app.main:app).
LOG_FORMAT=text
PORT=8080

DATABASE_URL=postgresql://ecom:ecom_dev_password@localhost:5432/ecommerce

# Optional - omit to run without caching.
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECS=60

JWT_ACCESS_SECRET=dev-access-secret-change-me-0123456789ab
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-0123456789
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000
JWT_ISSUER=ecommerce.python
JWT_AUDIENCE=ecommerce.api
