# Copy to .env for running the binary outside Docker (cargo run).
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=pretty
PORT=8080

DATABASE_URL=postgres://ecom:ecom_dev_password@localhost:5432/ecommerce
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2

# Optional - omit to run without caching.
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECS=60

# In production, source these from a secrets manager, never a file.
JWT_ACCESS_SECRET=dev-access-secret-change-me-0123456789ab
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-0123456789
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000
JWT_ISSUER=ecommerce.rust
JWT_AUDIENCE=ecommerce.api
